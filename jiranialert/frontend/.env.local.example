# Copy this file to .env.local and fill with your Firebase project values
# Vite requires env vars to be prefixed with VITE_

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Functions backend base. Use the same /api path locally and in production.
VITE_BACKEND_URL=/api
VITE_FUNCTIONS_BASE=/api

# Emulator selection:
# - To use the local Firebase emulator: leave VITE_USE_FIREBASE_EMULATORS blank or set it to auto
# - To force the emulator even if it is not running: set VITE_USE_FIREBASE_EMULATORS=true
# - To use your deployed Firebase project locally: set VITE_USE_FIREBASE_EMULATORS=false
#   and update VITE_BACKEND_URL to your deployed functions URL.
VITE_USE_FIREBASE_EMULATORS=auto

# Notes:
# - After adding values, restart the dev server: `npm run dev`
# - To use Firebase emulators, run the emulator from the backend folder (see backend/start-emulators.ps1 or `firebase emulators:start`).
# - Vite proxies /api to the local emulator during development.
# - Never commit real keys to source control. Keep secrets out of repo.
