# Copy this file to .env.local and fill with your Firebase project values
# Vite requires env vars to be prefixed with VITE_

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Functions backend base. Use the emulator locally, and your deployed Cloud Functions
# base URL in production.
VITE_BACKEND_URL=http://localhost:5002/jiranialert/us-central1
VITE_FUNCTIONS_BASE=http://localhost:5002/jiranialert/us-central1

# Notes:
# - After adding values, restart the dev server: `npm run dev`
# - To use Firebase emulators, run the emulator from the backend folder (see backend/start-emulators.ps1 or `firebase emulators:start`).
# - Never commit real keys to source control. Keep secrets out of repo.
