APP_URL=https://jirani-alert-frontend.vercel.app
MAIL_FROM="Jirani Alert <your-sender-email@gmail.com>"

# Gmail SMTP. Use a Gmail App Password, not your normal Gmail password.
# The resend/signup verification flow will not send mail until one of the SMTP options below is configured.
# App passwords are 16 characters and do not contain spaces.
GMAIL_USER=your-sender-email@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# A comma-separated list of super-admin addresses to notify about every emergency.
# Admin profiles in Firestore are also notified automatically.
SUPER_ADMIN_EMAILS=admin@example.com

# Alternative SMTP provider. Leave blank when using Gmail above.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Local email test endpoint secret. Set any value to protect the endpoint.
EMAIL_TEST_SECRET=your-test-secret
